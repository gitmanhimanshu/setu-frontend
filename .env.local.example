# Public URL of the Setu MCP server. Used for the connector URL shown on /connect
# and as the API origin for the dashboard.
NEXT_PUBLIC_SETU_URL=https://api.mimanasa.online

# Google OAuth client ID (public, not a secret) — used by the dashboard's
# "Sign in with Google". The site origin must be listed under "Authorized
# JavaScript origins" on this client in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
